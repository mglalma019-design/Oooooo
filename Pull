local MiscTab = Window:CreateTab("Misc", 4483362458)

MiscTab:CreateToggle({
   Name = "Instant Interact",
   CurrentValue = false,
   Flag = "InstantInteract",
   Callback = function(Value)
      _G.InstantInteract = Value
      if Value then
         local function optimizePrompt(prompt)
            if prompt:IsA("ProximityPrompt") then
               prompt.HoldDuration = 0
               prompt.MaxActivationDistance = 25 
            end
         end
         for _, v in pairs(game:GetDescendants()) do optimizePrompt(v) end
         _G.PromptConnection = game.DescendantAdded:Connect(function(descendant)
            if _G.InstantInteract then optimizePrompt(descendant) end
         end)
      else
         if _G.PromptConnection then _G.PromptConnection:Disconnect() end
      end
   end,
})

MiscTab:CreateButton({
   Name = "Destroy UI",
   Callback = function()
      if _G.PromptConnection then _G.PromptConnection:Disconnect() end
      Rayfield:Destroy()
   end,
})
